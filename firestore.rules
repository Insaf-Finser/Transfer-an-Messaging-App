rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isChatParticipant(chatId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // Username registry for uniqueness checks and user search.
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && username == request.resource.data.username;
      allow update, delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // users/{uid} — public keys and usernames readable by any signed-in user.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);

      match /info/{docId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    // chats/{chatId}
    match /chats/{chatId} {
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      allow read, update: if isSignedIn()
        && (resource == null
            || request.auth.uid in resource.data.participants);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);

        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.keys().hasAll([
               'senderId', 'ciphertext', 'iv', 'encryptedSessionKey', 'timestamp', 'type'
             ]);

        allow update, delete: if false;
      }
    }
  }
}
